node_modules/
dist/
.env
*.tgz
# CI image builds (GitHub runner) need the @wip lib tarballs in the repo —
# package.json references them as file: deps and the Dockerfile COPYs libs/.
!libs/*.tgz
*.whl
.DS_Store
.claude-context-pct
.claude/.session-id
yac-discussions

# Local/instance-specific — not tracked (durability is the kb mirror for reports;
# .mcp.json carries instance URLs + key-file paths; commands are refresh-delivered)
reports/
.mcp.json
.claude/commands/

# Python (kb-client loaders)
__pycache__/
*.pyc

# KB data exports / backups — data lives in the kb namespace, never the app repo
backup-files/

# Local-only: machine-specific session hooks + scratch evidence (screenshots etc.)
.claude/hooks/
evidence/
