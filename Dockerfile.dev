# Dockerfile.dev — development image for wip-deploy's --app-source override.
#
# Built by wip-deploy when invoked with:
#   wip-deploy add-app wip-kb --app-source ~/Development/WIP-KB
#
# Mirrors the canonical CASE-58 pattern (CT-YAC's design, RC's reference impl).
# The entrypoint script populates the named /app/node_modules volume on first
# start and re-runs npm ci when the host's package-lock.json hash changes.
#
# After install the CMD runs `npm run dev` — concurrently runs:
#   - dev:server: tsx watch server/index.ts → Express on PORT (3012)
#   - dev:client: vite → dev server + HMR on 5173
# Vite is configured with `host: '0.0.0.0'` so the container accepts
# connections from Caddy. See vite.config.ts.
#
# CHOKIDAR_USEPOLLING: reliable file-change detection on macOS bind mounts.
# NODE_ENV=development: belt-and-suspenders; the wip-deploy renderer also sets
# this, but keeping it in the image means a bare `docker run` still works.
FROM node:20-alpine

WORKDIR /app

COPY docker-entrypoint-dev.sh /entrypoint-dev.sh
RUN chmod +x /entrypoint-dev.sh

ENV CHOKIDAR_USEPOLLING=1 \
    NODE_ENV=development \
    PORT=3012

# 3012 = Express (tsx watch), 5173 = Vite dev server + HMR WebSocket
EXPOSE 3012 5173

ENTRYPOINT ["/entrypoint-dev.sh"]
CMD ["npm", "run", "dev"]
