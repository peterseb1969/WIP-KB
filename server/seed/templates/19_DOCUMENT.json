{
  "value": "DOCUMENT",
  "label": "Document",
  "description": "Mirror of a human-targeted markdown file from a source repo (CASE-346). v3 (CASE-481): identity is the KB-minted `paper_number` (per-type sequence, synonym PAPER-<n>) — NOT `path` (which collides across repos and breaks on rename). On first contact the gateway resolves by the composite search key (repo_origin, path) → adopts the existing paper_number or mints a new one; thereafter path/repo_origin are mutable non-identity fields. Generic — discriminated per-instance by `kind`.",
  "usage": "entity",
  "identity_fields": ["paper_number"],
  "header_fields": ["title", "kind"],
  "metadata": { "custom": { "write": { "number_field": "paper_number", "synonym_prefix": "PAPER", "search_key": ["repo_origin", "path"] } } },
  "fields": [
    { "name": "paper_number",    "label": "Paper Number",    "type": "integer", "mandatory": true },
    { "name": "path",            "label": "Path",            "type": "string",  "mandatory": true,  "full_text_indexed": true },
    { "name": "repo_origin",     "label": "Repo Origin",     "type": "string",  "mandatory": true },
    { "name": "title",           "label": "Title",           "type": "string",  "mandatory": true,  "full_text_indexed": true },
    { "name": "body",            "label": "Body",            "type": "string",  "mandatory": true,  "full_text_indexed": true },
    { "name": "kind",            "label": "Kind",            "type": "term",    "mandatory": true,  "reference_type": "term", "terminology_ref": "KB_DOC_KIND" },
    { "name": "authored_by",     "label": "Authored By",     "type": "string",  "mandatory": false },
    { "name": "tags",            "label": "Tags",            "type": "array",   "array_item_type": "string" },
    { "name": "synced_from_sha", "label": "Synced From SHA", "type": "string",  "mandatory": false },
    { "name": "doc_status",      "label": "Doc Status",      "type": "term",    "mandatory": true,  "reference_type": "term", "terminology_ref": "KB_DOC_STATUS", "default_value": "published" }
  ]
}
