{
  "value": "CASE_RECORD",
  "label": "Case Record",
  "description": "Cross-agent case filed by a YAC (DESIGN.md §5.1). v3 redesign (CASE-481): identity is `case_number` — the KB-minted handle, written into the doc as THE identity field AND registered as the `CASE-<n>` Registry synonym atomically at creation (the synonym claim is the race/uniqueness guard, CASE-427/436). The case body + all classification fields are the mutable, versioned current statement of the case (PoNIF #2); discourse lives in separate CASE_RESPONSE docs (RESPONDS_TO). Supersedes the v2 `identity_fields: []` loophole model (CASE-477/478).",
  "usage": "entity",
  "identity_fields": ["case_number"],
  "header_fields": ["title", "case_number", "status"],
  "metadata": { "custom": { "write": { "number_field": "case_number", "synonym_prefix": "CASE", "search_key": [] } } },
  "fields": [
    { "name": "title",       "label": "Title",        "type": "string",  "mandatory": true, "full_text_indexed": true },
    { "name": "body",        "label": "Body",         "type": "string",  "mandatory": true, "full_text_indexed": true },
    { "name": "authored_by", "label": "Authored By",  "type": "string",  "mandatory": true },
    { "name": "doc_status",  "label": "Doc Status",   "type": "term",    "mandatory": true, "reference_type": "term", "terminology_ref": "KB_DOC_STATUS", "default_value": "draft" },
    { "name": "tags",        "label": "Tags",         "type": "array",   "array_item_type": "string" },
    { "name": "root",        "label": "Root",         "type": "boolean", "default_value": false },
    { "name": "source_yac",  "label": "Source YAC",   "type": "string" },
    { "name": "target_yac",  "label": "Target YAC",   "type": "term",    "reference_type": "term", "terminology_ref": "KB_TARGET_YAC" },
    { "name": "case_number", "label": "Case Number",  "type": "integer", "mandatory": true },
    { "name": "status",      "label": "Status",       "type": "string",  "mandatory": false },
    { "name": "severity",    "label": "Severity",     "type": "string",  "mandatory": false },
    { "name": "type",        "label": "Type",         "type": "string",  "mandatory": false },
    { "name": "component",   "label": "Component",    "type": "string",  "mandatory": false },
    { "name": "filed_by",    "label": "Filed By",     "type": "string",  "mandatory": false },
    { "name": "app",         "label": "App",          "type": "string",  "mandatory": false }
  ]
}
