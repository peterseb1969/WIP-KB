{
  "value": "JOURNEY_ENTRY",
  "label": "Journey Entry",
  "description": "Day-journal entries persisted by FRanC via /kb-persist journey (DESIGN.md §5.5). Identity by journey_date — one journal per day. Title is not the identity because it iterates as the day's narrative develops.",
  "usage": "entity",
  "identity_fields": ["journey_date"],
  "fields": [
    { "name": "title",        "label": "Title",         "type": "string",  "mandatory": true, "full_text_indexed": true },
    { "name": "body",         "label": "Body",          "type": "string",  "mandatory": true, "full_text_indexed": true },
    { "name": "authored_by",  "label": "Authored By",   "type": "string",  "mandatory": true },
    { "name": "doc_status",   "label": "Doc Status",    "type": "term",    "mandatory": true, "reference_type": "term", "terminology_ref": "KB_DOC_STATUS", "default_value": "draft" },
    { "name": "tags",         "label": "Tags",          "type": "array",   "array_item_type": "string" },
    { "name": "root",         "label": "Root",          "type": "boolean", "default_value": false },
    { "name": "journey_date", "label": "Journey Date",  "type": "date",    "mandatory": true }
  ]
}
